NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/intothedark?schema=public
APP_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_another_random_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=itd_refresh
EMAIL_VERIFICATION_REQUIRED=false
RESEND_API_KEY=re_xxx
RESEND_FROM=noreply@example.com
CHARACTER_DATA_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ADMIN_API_KEY=replace_with_admin_api_key_for_notifications_publish
