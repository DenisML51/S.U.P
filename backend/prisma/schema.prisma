generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                  @id @default(cuid())
  name            String
  email           String                  @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  codes           EmailVerificationCode[]
  refreshTokens   RefreshToken[]
  characters      Character[]
  notificationReads UserNotificationRead[]
  hostedLobbies   Lobby[]                 @relation("LobbyHost")
  lobbyMembers    LobbyMember[]
  lobbyMessages   LobbyMessage[]
}

enum LobbyStatus {
  WAITING
  IN_COMBAT
  CLOSED
}

enum LobbyRole {
  MASTER
  PLAYER
}

enum MemberStatus {
  ONLINE
  OFFLINE
  LEFT
}

enum MessageVisibility {
  PLAYERS_ONLY
  ALL
}

model PendingRegistration {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  codeHash     String
  expiresAt    DateTime
  attempts     Int      @default(0)
  consumedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt, consumedAt])
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Character {
  id               String   @id @default(cuid())
  userId           String
  name             String
  class            String
  level            Int
  encryptedPayload String   @db.Text
  payloadIv        String
  payloadTag       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lobbyMembers LobbyMember[]

  @@index([userId, updatedAt])
  @@index([userId, name])
}

model Lobby {
  id         String        @id @default(cuid())
  key        String        @unique
  hostId     String
  status     LobbyStatus   @default(WAITING)
  settings   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  host       User          @relation("LobbyHost", fields: [hostId], references: [id], onDelete: Cascade)
  members    LobbyMember[]
  messages   LobbyMessage[]
  combatState CombatState?

  @@index([hostId, status])
  @@index([status, createdAt])
}

model LobbyMember {
  id               String       @id @default(cuid())
  lobbyId          String
  userId           String
  characterId      String?
  role             LobbyRole    @default(PLAYER)
  status           MemberStatus @default(ONLINE)
  currentAction    String?
  currentHP        Int?
  maxHP            Int?
  joinedAt         DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  leftAt           DateTime?

  lobby            Lobby        @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  character        Character?   @relation(fields: [characterId], references: [id], onDelete: SetNull)
  activeInCombats  CombatState[] @relation("ActiveCombatMember")

  @@unique([lobbyId, userId])
  @@index([lobbyId, status])
  @@index([userId])
}

model LobbyMessage {
  id         String            @id @default(cuid())
  lobbyId    String
  senderId   String
  senderRole LobbyRole
  content    String            @db.Text
  visibility MessageVisibility @default(PLAYERS_ONLY)
  createdAt  DateTime          @default(now())

  lobby      Lobby             @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  sender     User              @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([lobbyId, createdAt])
}

model CombatState {
  id             String       @id @default(cuid())
  lobbyId        String       @unique
  round          Int          @default(1)
  activeMemberId String?
  turnOrder      Json?
  snapshot       Json?
  isInCombat     Boolean      @default(false)
  updatedAt      DateTime     @updatedAt

  lobby          Lobby        @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  activeMember   LobbyMember? @relation("ActiveCombatMember", fields: [activeMemberId], references: [id], onDelete: SetNull)

  @@index([activeMemberId])
}

model SystemNotification {
  id          String   @id @default(cuid())
  title       String
  message     String   @db.Text
  type        String   @default("info")
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reads       UserNotificationRead[]

  @@index([isActive, publishedAt])
}

model UserNotificationRead {
  id             String   @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime @default(now())

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification SystemNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId, readAt])
}
